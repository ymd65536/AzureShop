{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "75212437205673970"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "eastus2",
      "metadata": {
        "description": "Azure region for Function App and supporting resources. Use a region with available quota, such as eastus2."
      }
    },
    "staticWebAppLocation": {
      "type": "string",
      "defaultValue": "eastus2",
      "metadata": {
        "description": "Azure region for the Static Web App. Static Web Apps is available in eastus2, westus2, centralus, eastasia, and westeurope."
      }
    },
    "webServiceName": {
      "type": "string",
      "defaultValue": "stapp-azure-shop-demo",
      "metadata": {
        "description": "Name of the web service resource for azd"
      }
    },
    "cosmosAccountName": {
      "type": "string",
      "defaultValue": "[take(toLower(format('cosmos{0}', uniqueString(subscription().subscriptionId, resourceGroup().id, parameters('location')))), 44)]",
      "metadata": {
        "description": "Name of the Cosmos DB account"
      }
    },
    "cosmosDatabaseName": {
      "type": "string",
      "defaultValue": "shopdb",
      "metadata": {
        "description": "Name of the Cosmos DB database"
      }
    },
    "cosmosContainerName": {
      "type": "string",
      "defaultValue": "orders",
      "metadata": {
        "description": "Name of the Cosmos DB container"
      }
    },
    "functionAppName": {
      "type": "string",
      "defaultValue": "[format('func-{0}', uniqueString(subscription().subscriptionId, resourceGroup().id, parameters('location')))]",
      "metadata": {
        "description": "Name of the Function App"
      }
    },
    "functionStorageAccountName": {
      "type": "string",
      "defaultValue": "[take(toLower(format('st{0}', uniqueString(subscription().subscriptionId, resourceGroup().id, parameters('location')))), 24)]",
      "metadata": {
        "description": "Name of the storage account for the Function App"
      }
    },
    "appInsightsName": {
      "type": "string",
      "defaultValue": "[format('appi-{0}', uniqueString(resourceGroup().id, parameters('location')))]",
      "metadata": {
        "description": "Name of the Application Insights resource"
      }
    },
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "[format('asp-{0}', uniqueString(resourceGroup().id, parameters('location')))]",
      "metadata": {
        "description": "Name of the Consumption plan for the Function App"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('webServiceName')]",
      "location": "[parameters('staticWebAppLocation')]",
      "tags": {
        "azd-service-name": "web"
      },
      "sku": {
        "name": "Standard",
        "tier": "Standard"
      },
      "properties": {
        "repositoryUrl": "https://github.com/Azure/azure-quickstart-templates",
        "branch": "master",
        "buildProperties": {
          "appLocation": "/",
          "apiLocation": "/api",
          "outputLocation": ""
        }
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2024-05-15",
      "name": "[parameters('cosmosAccountName')]",
      "location": "[parameters('location')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "locations": [
          {
            "locationName": "[parameters('location')]",
            "failoverPriority": 0,
            "isZoneRedundant": false
          }
        ],
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "capabilities": [
          {
            "name": "EnableServerless"
          }
        ]
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2024-05-15",
      "name": "[format('{0}/{1}', parameters('cosmosAccountName'), parameters('cosmosDatabaseName'))]",
      "properties": {
        "resource": {
          "id": "[parameters('cosmosDatabaseName')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2024-05-15",
      "name": "[format('{0}/{1}/{2}', parameters('cosmosAccountName'), parameters('cosmosDatabaseName'), parameters('cosmosContainerName'))]",
      "properties": {
        "resource": {
          "id": "[parameters('cosmosContainerName')]",
          "partitionKey": {
            "paths": [
              "/customerId"
            ],
            "kind": "Hash"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', parameters('cosmosAccountName'), parameters('cosmosDatabaseName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[parameters('functionStorageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2"
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[parameters('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": null,
        "Flow_Type": "Bluefield",
        "Request_Source": "rest"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "kind": "functionapp"
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "appSettings": [
            {
              "name": "AzureWebJobsStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', parameters('functionStorageAccountName'), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('functionStorageAccountName')), '2023-05-01').keys[0].value)]"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "node"
            },
            {
              "name": "WEBSITE_NODE_DEFAULT_VERSION",
              "value": "~20"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', parameters('appInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[reference(resourceId('Microsoft.Insights/components', parameters('appInsightsName')), '2020-02-02').InstrumentationKey]"
            },
            {
              "name": "COSMOS_ENDPOINT",
              "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName')), '2024-05-15').documentEndpoint]"
            },
            {
              "name": "COSMOS_KEY",
              "value": "[listKeys(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName')), '2024-05-15').primaryMasterKey]"
            },
            {
              "name": "COSMOS_DATABASE",
              "value": "[parameters('cosmosDatabaseName')]"
            },
            {
              "name": "COSMOS_CONTAINER",
              "value": "[parameters('cosmosContainerName')]"
            },
            {
              "name": "COSMOS_PRODUCTS_CONTAINER",
              "value": "products"
            }
          ],
          "ftpsState": "FtpsOnly",
          "minTlsVersion": "1.2"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', parameters('appInsightsName'))]",
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName'))]",
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('functionStorageAccountName'))]"
      ]
    }
  ],
  "outputs": {
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName')), '2024-05-15').documentEndpoint]"
    },
    "webUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', parameters('webServiceName')), '2023-12-01').defaultHostname)]"
    },
    "functionAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01').defaultHostName)]"
    },
    "applicationInsightsConnectionString": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', parameters('appInsightsName')), '2020-02-02').ConnectionString]"
    }
  }
}